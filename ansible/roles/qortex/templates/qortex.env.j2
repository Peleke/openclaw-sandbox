# {{ ansible_managed }}
# Environment for qortex HTTP service (systemd EnvironmentFile)

# Vector backend
QORTEX_VEC={{ qortex_vec_backend | default('sqlite') }}
{% if qortex_vec_backend | default('sqlite') == 'pgvector' %}
PGVECTOR_DSN={{ qortex_pgvector_dsn }}
{% endif %}

# API authentication
{% if qortex_api_keys | default('') | length > 0 %}
QORTEX_API_KEYS={{ qortex_api_keys }}
{% endif %}
{% if qortex_hmac_secret | default('') | length > 0 %}
QORTEX_HMAC_SECRET={{ qortex_hmac_secret }}
{% endif %}

# Extraction strategy
QORTEX_EXTRACTION={{ qortex_extraction | default('spacy') }}

# Memgraph (when enabled)
{% if memgraph_enabled | default(false) | bool %}
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT={{ memgraph_bolt_port | default(7687) }}
MEMGRAPH_USER={{ memgraph_user | default('memgraph') }}
MEMGRAPH_PASSWORD={{ memgraph_password | default('memgraph') }}
{% endif %}

# OpenTelemetry (when enabled)
{% if qortex_otel_enabled | default(false) | bool %}
OTEL_EXPORTER_OTLP_ENDPOINT={{ qortex_otel_endpoint }}
OTEL_EXPORTER_OTLP_PROTOCOL={{ qortex_otel_protocol | default('http/protobuf') }}
OTEL_SERVICE_NAME=qortex
{% endif %}

# Prometheus metrics
{% if qortex_prometheus_enabled | default(false) | bool %}
QORTEX_PROMETHEUS_PORT={{ qortex_prometheus_port | default(9090) }}
{% endif %}
